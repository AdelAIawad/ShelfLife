# Node environment (development | production)
NODE_ENV=development

# MongoDB connection
# - Leave blank or use default for in-memory auto-start (dev only)
# - For production, use MongoDB Atlas connection string
MONGO_URI=mongodb://localhost:27017/shelflife

# JWT secret — GENERATE A STRONG RANDOM STRING IN PRODUCTION
# e.g. node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=shelflife_jwt_secret_key_change_me

# Backend server port
PORT=5001
SERVER_PORT=5001

# Google Books API key (optional — works without, but with daily rate limits)
# Get one at https://console.cloud.google.com/apis/credentials
GOOGLE_BOOKS_API_KEY=

# Frontend URL (production only — for CORS)
# FRONTEND_URL=https://your-app.onrender.com
