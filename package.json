{
  "name": "shelflife",
  "version": "1.0.0",
  "description": "ShelfLife - Book Tracker Web Application",
  "scripts": {
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "dev": "concurrently -n server,client -c blue,green \"npm run server\" \"npm run client\"",
    "build": "cd client && npm run build",
    "seed": "node server/seed.js",
    "install-all": "npm install && cd client && npm install",
    "start": "npm run dev"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb-memory-server": "^11.0.1",
    "mongoose": "^8.6.0",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-icons": "^5.6.0",
    "sharp": "^0.34.5"
  }
}
